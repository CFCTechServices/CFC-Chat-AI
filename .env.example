# =============================================================================
# CFC Chat AI — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Pinecone (vector store for RAG)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=cfc-rag-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=cfc-knowledge-base

# Separate index for video transcripts (defaults to PINECONE_INDEX_NAME if unset)
PINECONE_VIDEO_INDEX_NAME=cfc-videos

# -----------------------------------------------------------------------------
# Supabase (database + auth)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co/
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage buckets
SUPABASE_BUCKET=cfc-docs
SUPABASE_BUCKET_VIDEOS=cfc-videos

# -----------------------------------------------------------------------------
# AI Models — Azure OpenAI
# Get these from: Azure Portal → your OpenAI resource → Keys and Endpoint
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# -----------------------------------------------------------------------------
# Email / Invitation system (Resend) — optional
# Set RESEND_API_KEY to enable email invitations.
# Leave commented out to create invitations without sending email.
# -----------------------------------------------------------------------------
# RESEND_API_KEY=your-resend-api-key
# ENABLE_EMAIL_INVITES=true

# Base URL used in invitation and password-reset email links.
# Must match a redirect URL whitelisted in Supabase → Authentication → URL Configuration.
# Local dev: http://localhost:8000
# Production (VM): http://192.168.33.211  (or your domain once registered)
FRONTEND_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of origins the browser is allowed to call the API from.
# Local dev:  http://localhost:8000
# Production: http://192.168.33.211  (or your domain once registered)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:8000

# -----------------------------------------------------------------------------
# API Server (FastAPI / uvicorn)
# These rarely need to change.
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Test credentials (used by test suite only — never put real users here)
# -----------------------------------------------------------------------------
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=change-me
TEST_TARGET_USER_ID=