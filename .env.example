# =============================================================================
# CFC Chat AI — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Pinecone (vector store for RAG)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=cfc-rag-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=cfc-knowledge-base

# Separate index for video transcripts (defaults to PINECONE_INDEX_NAME if unset)
PINECONE_VIDEO_INDEX_NAME=cfc-videos

# -----------------------------------------------------------------------------
# Supabase (database + auth)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co/
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage buckets
SUPABASE_BUCKET=cfc-docs
SUPABASE_BUCKET_VIDEOS=cfc-videos

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------
# Google Gemini (primary LLM)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (optional — not required unless switching LLM provider)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of origins the browser is allowed to call the API from.
# In production this should be your domain only.
# For local dev: http://localhost:8000
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend Base URL
# Used as the redirect target in password-reset emails sent via Supabase Auth.
# For local dev: http://localhost:8000
# In production: your public domain (must match what Supabase has whitelisted)
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# API Server (FastAPI / gunicorn)
# These rarely need to change — the defaults work for Docker.
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Test credentials (used by test suite only — never put real users here)
# -----------------------------------------------------------------------------
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=change-me
TEST_TARGET_USER_ID=