PINECONE_API_KEY=
PINECONE_INDEX_NAME=cfc-rag-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=cfc-knowledge-base
EMBED_MODEL=all-MiniLM-L6-v2
# Optional: Supabase Storage (if used)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET_VIDEOS= cfc-videos

# Azure OpenAI (required for AI chat responses)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview
SESSION_SECRET=


SESSION_COOKIE_NAME=CFC_SESSION
SESSION_TTL_DAYS=7
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
# if CORS_ORIGINS is used:
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENV=development

# For production (when CFC website is live)
CFC_WEBSITE_URL=https://cfc-website.com

# For development/testing (disable protection)
ENABLE_REFERRER_PROTECTION=false