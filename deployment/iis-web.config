<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config — Reverse proxy and static file configuration for CFC Chat AI
  
  This replaces nginx.conf.example for Windows VM hosting.

  Prerequisites:
    - IIS installed with URL Rewrite Module and ARR (Application Request Routing)
    - ARR proxy must be enabled:
        1. Open IIS Manager
        2. Click the server name (top level)
        3. Double-click "Application Request Routing Cache"
        4. Click "Server Proxy Settings" in the Actions pane
        5. Check "Enable proxy" and click Apply

  Setup:
    1. Create a new IIS Site pointing to the web root (e.g., C:\inetpub\cfcchat)
    2. Copy this file into that web root as "web.config"
    3. Copy frontend files into the same folder (deploy.ps1 does this automatically)
    4. Bind the site to port 80 (and 443 for HTTPS)

  The Docker container must be running on 127.0.0.1:8000.
-->
<configuration>
  <system.webServer>

    <!-- Enable URL Rewrite rules -->
    <rewrite>
      <rules>
        <!--
          Rule 1: Reverse proxy /api/* requests to the Docker container.
          This is equivalent to nginx's proxy_pass directive.
        -->
        <rule name="ReverseProxyAPI" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/api/{R:1}" />
        </rule>

        <!--
          Rule 2: SPA catch-all for client-side routes.
          Routes like /chat, /admin, /settings etc. serve index.html
          so React's client-side router can handle them.
          
          Skip if the request maps to an actual file (JS, CSS, images).
        -->
        <rule name="SPACatchAll" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/ui/" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!--
      Increase request size limits for large file uploads (documents, videos).
      Equivalent to nginx's client_max_body_size 500M.
    -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

    <!--
      MIME type mappings for JSX files used by the frontend.
      IIS doesn't know about .jsx by default.
    -->
    <staticContent>
      <remove fileExtension=".jsx" />
      <mimeMap fileExtension=".jsx" mimeType="text/jsx" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <!--
      Extend timeouts for long-running API operations (Whisper transcription).
      Equivalent to nginx's proxy_read_timeout 300s.
    -->
    <proxy timeout="00:05:00" />

  </system.webServer>
</configuration>
